<resources>

    <!-- Base Material 3 application theme. Dynamic colors are applied programmatically
         in BleAdvertiserApplication when the user opts in (default on Android 12+). -->
    <style name="Theme.BleAdvertiserPro" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/m3_primary</item>
        <item name="colorOnPrimary">@color/m3_on_primary</item>
        <item name="colorPrimaryContainer">@color/m3_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/m3_on_primary_container</item>

        <item name="colorSecondary">@color/m3_secondary</item>
        <item name="colorOnSecondary">@color/m3_on_secondary</item>
        <item name="colorSecondaryContainer">@color/m3_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/m3_on_secondary_container</item>

        <item name="colorTertiary">@color/m3_tertiary</item>
        <item name="colorOnTertiary">@color/m3_on_tertiary</item>

        <item name="colorError">@color/m3_error</item>
        <item name="colorOnError">@color/m3_on_error</item>

        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="colorPrimaryVariant">@color/m3_primary_container</item>
        <item name="colorSecondaryVariant">@color/m3_secondary_container</item>

        <item name="seekbarBackground">@color/grey_normal</item>
        <item name="seekbarProgress">?attr/colorPrimary</item>
        <item name="seekbarSecondaryProgress">?attr/colorPrimaryContainer</item>
    </style>

    <style name="Theme.BleAdvertiserPro.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="ActionButton.Overflow.Icon" parent="android:style/Widget.Holo.Light.ActionButton.Overflow">
        <item name="android:src">@drawable/settings</item>
        <item name="color">@color/foreground_color_action_bar</item>
        <item name="tint">@color/foreground_color_action_bar</item>
    </style>

    <style name="Theme.BleAdvertiserPro.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:actionOverflowButtonStyle">@style/ActionButton.Overflow.Icon</item>
    </style>

</resources>
